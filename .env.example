# PostgreSQL na VPS
DATABASE_URL="postgresql://buildflow:senha_forte@localhost:5432/buildflow?schema=public"

# Auth (gere com: openssl rand -base64 32)
AUTH_SECRET="troque_este_valor_por_um_secret_forte"

# Caminho ABSOLUTO da pasta de uploads no servidor.
# Producao (VPS):  /var/www/app/uploads
# Dev local:       ./uploads
UPLOAD_DIR="./uploads"

# URL publica base dos uploads (Nginx faz alias para UPLOAD_DIR)
# Producao: https://seu-dominio.com/uploads
NEXT_PUBLIC_UPLOAD_BASE_URL="/uploads"
