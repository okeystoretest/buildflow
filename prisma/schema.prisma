// Build.Flow - schema v2 (PostgreSQL)
// Regra de ouro: imagens/arquivos NUNCA viram blob. So o caminho (String).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// USUARIOS / PERFIS
// ===========================================================================

enum Role {
  GESTAO
  VENDAS
  FINANCEIRO
  LOGISTICA
  MOTORISTA
}

// Modelo de venda do vendedor: trava o escopo de tudo que ele vende.
enum SalesModel {
  VAREJO
  ATACADO
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  // Obrigatorio para VENDAS; null para os demais perfis.
  salesModel SalesModel?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersAsSeller Order[]        @relation("OrderSeller")
  deliveries     Delivery[]     @relation("DeliveryDriver")
  notifications  Notification[]
  salesGoals     SalesGoal[]
  dailyTasks     DailyTask[]

  @@index([role])
}

// ===========================================================================
// CADASTROS DE APOIO (gerenciados pela Gestao)
// ===========================================================================

model Store {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model OrderType {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Operation {
  id        String   @id @default(cuid())
  code      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model ShippingMethod {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Bank {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orders Order[]
}

// CNPJ da empresa (cadastro do Financeiro). Vinculado ao pedido na analise.
model Cnpj {
  id        String   @id @default(cuid())
  // Razao social / apelido para exibir no select.
  name      String
  // Numero do CNPJ (somente digitos ou formatado). Unico.
  document  String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([active])
}

model PaymentStatusOption {
  id          String             @id @default(cuid())
  name        String
  disposition PaymentDisposition
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  orders      Order[]
}

enum PaymentDisposition {
  APROVA
  INTERROMPE
}

// ===========================================================================
// CLIENTES
// ===========================================================================

model Customer {
  id        String   @id @default(cuid())
  // Codigo do cliente (unico, obrigatorio).
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([name])
}

// ===========================================================================
// PRODUTOS / ESTOQUE
// ===========================================================================

model Product {
  id        String   @id @default(cuid())
  sku       String   @unique
  name      String
  price     Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([active])
}

// ===========================================================================
// PEDIDOS
// ===========================================================================

enum OrderStatus {
  EM_ANALISE
  AGUARDANDO_IMPRESSAO
  SEPARANDO
  PENDENTE
  CONFERINDO
  EMBALANDO
  EMBALADO
  PROCESSANDO
  PROCESSADO
  ENVIADO
  EM_ROTA
  ENTREGUE
  CONCLUIDO
  ESTORNO
  ESTORNO_PARCIAL
  CANCELADO
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String
  comandaNumber String?
  status        OrderStatus @default(EM_ANALISE)

  store       Store     @relation(fields: [storeId], references: [id])
  storeId     String
  orderType   OrderType @relation(fields: [orderTypeId], references: [id])
  orderTypeId String
  operation   Operation @relation(fields: [operationId], references: [id])
  operationId String

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  seller   User   @relation("OrderSeller", fields: [sellerId], references: [id])
  sellerId String

  // Forma de pagamento e Banco: preenchidos pelo FINANCEIRO na Analise de
  // Pedidos (nao mais no formulario de Vendas). Por isso sao opcionais no
  // cadastro; a obrigatoriedade e aplicada na hora de APROVAR o pedido.
  paymentMethod    PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId  String?
  shippingMethod   ShippingMethod @relation(fields: [shippingMethodId], references: [id])
  shippingMethodId String

  // Banco da transação (selecionado pelo Financeiro).
  bank   Bank?   @relation(fields: [bankId], references: [id])
  bankId String?

  paymentStatus   PaymentStatusOption? @relation(fields: [paymentStatusId], references: [id])
  paymentStatusId String?

  // CNPJ vinculado ao pedido pelo Financeiro (obrigatorio antes de aprovar).
  cnpj   Cnpj?   @relation(fields: [cnpjId], references: [id])
  cnpjId String?

  // Codigo de rastreio informado na transicao para PROCESSADO (opcional).
  trackingCode String?

  // Vinculo opcional a uma campanha (meta por volume de itens).
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?
  // Quantidade de itens que este pedido contribui para a campanha.
  itemCount  Int       @default(0)

  orderValue Decimal @default(0) @db.Decimal(10, 2)
  freight    Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @default(0) @db.Decimal(10, 2)

  // Comprovante enviado pela Vendedora na criacao do pedido.
  // MANTIDO por compatibilidade: pedidos antigos usam este campo unico.
  // Pedidos novos gravam ate 5 comprovantes na tabela OrderPaymentProof.
  paymentProofPath String?
  // Segundo comprovante, anexado pelo FINANCEIRO na Analise de Pedidos.
  // Obrigatorio para aprovar. Visivel a todos ao expandir o card no fluxo.
  paymentProof2Path String?
  invoicePath      String?

  notes String?

  // Pendencia sinalizada pelo FINANCEIRO ("Qual o problema?").
  // - financeIssue: texto da inconsistencia (null = sem pendencia ativa).
  // - financeIssueAt: quando foi sinalizada.
  // - financeIssueResolvedAt: quando VENDAS marcou como resolvida
  //   (se preenchido com issue ainda presente, ficou resolvida; usamos os
  //    dois para saber se a pendencia esta ATIVA ou ja RESOLVIDA).
  financeIssue           String?
  financeIssueAt         DateTime?
  financeIssueResolvedAt DateTime?

  items         OrderItem[]
  paymentProofs OrderPaymentProof[]
  financeProofs OrderFinanceProof[]
  delivery      Delivery?
  history       OrderStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([sellerId])
  @@index([customerId])
  @@index([createdAt])
  @@index([campaignId])
  @@index([cnpjId])
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  @@index([orderId])
}

// Comprovantes de pagamento enviados pela Vendedora no Novo Pedido.
// Um pedido aceita ate 5 (o limite e aplicado na action, nao no banco).
// Segue a regra do projeto: aqui vai apenas o CAMINHO do arquivo (.webp no
// disco), nunca o binario.
model OrderPaymentProof {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  filePath  String
  width     Int?
  height    Int?
  sizeBytes Int?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// Comprovantes anexados pelo FINANCEIRO na Analise de Pedidos (ate 5).
// O PRIMEIRO tambem e espelhado em Order.paymentProof2Path, que continua
// sendo a trava de aprovacao (nao quebrar essa regra).
model OrderFinanceProof {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  filePath  String
  width     Int?
  height    Int?
  sizeBytes Int?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  status    OrderStatus
  changedBy String?
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

// ===========================================================================
// ENTREGA / MOTORISTAS
// ===========================================================================

enum DeliveryStatus {
  AGUARDANDO
  ATRIBUIDA
  EM_ROTA
  ENTREGUE
  FALHOU
}

model Delivery {
  id     String         @id @default(cuid())
  status DeliveryStatus @default(AGUARDANDO)

  order   Order  @relation(fields: [orderId], references: [id])
  orderId String @unique

  driver   User?   @relation("DeliveryDriver", fields: [driverId], references: [id])
  driverId String?

  assignedAt  DateTime?
  startedAt   DateTime?
  deliveredAt DateTime?
  failReason  String?

  proofs Proof[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([driverId])
}

model Proof {
  id         String   @id @default(cuid())
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  deliveryId String
  filePath   String
  width      Int?
  height     Int?
  sizeBytes  Int?
  createdAt  DateTime @default(now())

  @@index([deliveryId])
}

// ===========================================================================
// NOTIFICACOES
// ===========================================================================

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  message   String
  orderId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// ===========================================================================
// METAS E CAMPANHAS (Rank de Vendas)
// ===========================================================================

// Meta financeira individual (por usuario, mes/ano, escopo).
// IMPORTANTE: a unicidade NAO usa @@unique aqui porque o Prisma nao suporta
// indice unico PARCIAL (com WHERE). A regra correta vive na migration SQL:
//   - Meta GERAL    (campaignId NULL):     unica por (user, mes, ano, escopo)
//   - Meta CAMPANHA (campaignId NOT NULL): unica por (user, mes, ano, escopo, campanha)
// Assim a Geral e as varias metas de Campanha convivem sem se sobrescrever.
model SalesGoal {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  amount    Decimal    @db.Decimal(12, 2) // meta em R$ (usada quando Geral)
  // Meta por quantidade de itens. Usada quando a meta é vinculada a Campanha.
  targetItems Int?
  month     Int        // 1-12
  year      Int
  scope     SalesModel // ATACADO ou VAREJO
  // null = meta Geral; preenchido = meta vinculada a uma Campanha.
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignId String?
  createdAt DateTime   @default(now())

  @@index([userId, month, year])
  @@index([month, year])
  @@index([campaignId])
}

// Campanha: apenas o nome (cadastro simples). As metas vinculadas
// a ela ficam em SalesGoal (campo campaignId).
model Campaign {
  id         String   @id @default(cuid())
  name       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  orders Order[]
  goals  SalesGoal[]
}

// ===========================================================================
// TAREFAS DIARIAS (Kanban da vendedora)
// ===========================================================================

// Status do quadro de tarefas: A Fazer -> Fazendo -> Concluida.
enum TaskStatus {
  A_FAZER
  FAZENDO
  CONCLUIDA
}

// Tarefa diaria de uma vendedora. Kanban pessoal (cada uma ve as proprias;
// a Gestao ve todas). "category" e texto livre digitado pela vendedora.
model DailyTask {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  // Horarios do dia em texto "HH:MM" (simples; a tarefa e do dia corrente).
  startTime String?
  endTime   String?
  category  String?
  notes     String?
  status    TaskStatus @default(A_FAZER)
  // Ordem manual dentro da coluna (para reordenacao futura; menor = topo).
  position  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, status])
  @@index([createdAt])
}
